<script>
  async function handleContactSubmit(e) {
    e.preventDefault();
    const form = e.target;
    const data = new FormData(form);
    try {
      await fetch('/', { method: 'POST', body: data });
    } catch(err) {}
    const btn = form.querySelector('.btn-submit');
    btn.textContent = '✅ Enviado!';
    btn.style.background = '#4ecca3';
    btn.style.color = '#0a0a0a';
    document.getElementById('successMsg').style.display = 'block';
    setTimeout(() => {
      form.reset();
      btn.textContent = 'Enviar Mensagem ✦';
      btn.style.background = '';
      btn.style.color = '';
      document.getElementById('successMsg').style.display = 'none';
    }, 3500);
  }

  // MODAL
  function openModal() {
    document.getElementById('modalOverlay').classList.add('open');
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    document.getElementById('modalOverlay').classList.remove('open');
    document.body.style.overflow = '';
    setTimeout(() => {
      document.getElementById('modalSuccess').style.display = 'none';
      document.querySelector('.modal-form').style.display = 'block';
      document.querySelector('.modal-title').style.display = 'block';
      document.querySelector('.modal-sub').style.display = 'block';
      document.querySelector('.modal-form').reset();
    }, 300);
  }

  function closeModalOutside(e) {
    if (e.target === document.getElementById('modalOverlay')) closeModal();
  }

  async function handleModalSubmit(e) {
    e.preventDefault();
    const form = e.target;
    const data = new FormData(form);
    try {
      await fetch('/', { method: 'POST', body: data });
    } catch(err) {}
    form.style.display = 'none';
    document.querySelector('.modal-title').style.display = 'none';
    document.querySelector('.modal-sub').style.display = 'none';
    document.getElementById('modalSuccess').style.display = 'block';
    setTimeout(() => closeModal(), 3500);
  }

  // ESC key closes modal
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeModal();
  });

  // SCROLL REVEAL
  const reveals = document.querySelectorAll('.reveal');
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry, i) => {
      if (entry.isIntersecting) {
        setTimeout(() => entry.target.classList.add('visible'), i * 80);
      }
    });
  }, { threshold: 0.1 });
  reveals.forEach(el => observer.observe(el));

  // NAV SCROLL
  window.addEventListener('scroll', () => {
    const nav = document.getElementById('navbar');
    if (window.scrollY > 50) {
      nav.style.padding = '0.8rem 5%';
      nav.style.borderBottomColor = 'rgba(255,214,0,0.15)';
    } else {
      nav.style.padding = '1.2rem 5%';
      nav.style.borderBottomColor = 'rgba(255,214,0,0.1)';
    }
  });

  // HAMBURGER
  function toggleMenu() {
    const menu = document.getElementById('mobileMenu');
    menu.classList.toggle('open');
  }
</script>   
